@model List<CatalogoApp.Domain.Models.Item>

@{
    ViewData["Title"] = "PlayStation Game Catalog";
}

<div class="container mt-4">

    @if (Model.Any())
    {
        <section class="hero-banner mb-5"
                 aria-label="Juegos destacados">

            @foreach (var item in Model.Take(5))
            {
                <div class="hero-slide"
                     style="background-image: url('@item.ImagenUrl');">

                    <div class="hero-overlay"></div>

                    <div class="hero-content">

                        <span class="detalle-badge">
                            @item.Genero
                        </span>

                        <h2 class="hero-title">
                            @item.Nombre
                        </h2>

                        <p class="hero-description">
                            @(item.Descripcion.Length > 170
                                ? item.Descripcion.Substring(0, 170) + "..."
                                : item.Descripcion)
                        </p>

                        <a asp-action="Detalle"
                           asp-route-id="@item.Id"
                           class="hero-button">
                            Ver detalles
                        </a>

                    </div>

                </div>
            }

        </section>
    }

    <h1 class="titulo-principal mb-4">
        PlayStation Game Catalog
    </h1>

    <div class="busqueda-container mb-4">

        <input type="text"
               id="busquedaJuego"
               class="form-control buscador-juegos"
               placeholder="Buscar videojuegos..." />

    </div>

    <form method="get" class="mb-4">

        <select name="genero"
                class="form-select filtro-ps"
                onchange="this.form.submit()">

            <option value="">
                Todos los géneros
            </option>

            @foreach (var genero in ViewBag.Generos)
            {
                if (ViewBag.GeneroActual == genero)
                {
                    <option value="@genero" selected>
                        @genero
                    </option>
                }
                else
                {
                    <option value="@genero">
                        @genero
                    </option>
                }
            }

        </select>

    </form>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4 juego-card">

                <div class="card tarjeta-ps h-100">

                    <a asp-action="Detalle"
                       asp-route-id="@item.Id"
                       class="card-link">

                        <div class="contenedor-imagen">

                            <img src="@(string.IsNullOrEmpty(item.ImagenUrl) 
                                 ? Url.Content("~/images/placeholder.jpg") 
                                 : item.ImagenUrl)"
                                 class="card-img-top imagen-juego"
                                 onerror="this.onerror=null;this.src='@Url.Content("~/images/placeholder.jpg")';" />
                                 class="card-img-top imagen-juego" />

                            <div class="overlay-juego">

                                <span class="badge bg-primary">
                                    @item.Genero
                                </span>

                            </div>

                        </div>

                        <div class="card-body">

                            <h4 class="titulo-juego">
                                @item.Nombre
                            </h4>

                            <p class="desarrollador-juego">
                                @item.Desarrollador
                            </p>

                            <p class="descripcion-juego">
                                @item.Descripcion
                            </p>

                        </div>

                    </a>

                    <div class="card-footer
                        footer-juego
                        d-flex
                        justify-content-between
                        align-items-center">

                        <div>

                            <span class="plataforma-juego">
                                @item.Plataforma
                            </span>

                        </div>

                        <div class="d-flex gap-2 align-items-center">

                            <form asp-action="FavoritoPost"
                                  method="post"
                                  class="d-inline">

                                <input type="hidden"
                                       name="id"
                                       value="@item.Id" />

                                <input type="hidden"
                                       name="returnUrl"
                                       value="@(Context.Request.Path + Context.Request.QueryString)" />

                                <button type="submit"
                                        class="btn btn-favorito @(item.Favorito ? "favorito-activo" : string.Empty)">

                                    @(item.Favorito ? "❤" : "♡")

                                </button>

                            </form>

                            <form asp-action="EliminarPost"
                                  method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('¿Eliminar este juego?');">

                                <input type="hidden"
                                       name="id"
                                       value="@item.Id" />

                                <button type="submit"
                                        class="btn btn-danger btn-sm">

                                    Eliminar

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<script>

    const buscador =
        document.getElementById("busquedaJuego");

    buscador.addEventListener("keyup", function () {

        const texto =
            buscador.value.toLowerCase();

        const juegos =
            document.querySelectorAll(".juego-card");

        juegos.forEach(juego => {

            const nombre =
                juego.innerText.toLowerCase();

            if (nombre.includes(texto)) {

                juego.style.display = "";

            } else {

                juego.style.display = "none";
            }

        });

    });

</script>

@section Scripts {
    <script src="~/js/hero-banner.js"
            asp-append-version="true"></script>
}
