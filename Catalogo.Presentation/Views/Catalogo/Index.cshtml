@model List<CatalogoApp.Domain.Models.Item>

@{
    ViewData["Title"] = "PlayStation Game Catalog";
}

<div class="container mt-4">

    <h1 class="titulo-principal mb-4">
        PlayStation Game Catalog
    </h1>

    <div class="busqueda-container mb-4">

        <input type="text"
               id="busquedaJuego"
               class="form-control buscador-juegos"
               placeholder="Buscar videojuegos..." />

    </div>

    <form method="get" class="mb-4">

        <select name="genero"
                class="form-select filtro-ps"
                onchange="this.form.submit()">

            <option value="">
                Todos los géneros
            </option>

            @foreach (var genero in ViewBag.Generos)
            {
                if (ViewBag.GeneroActual == genero)
                {
                    <option value="@genero" selected>
                        @genero
                    </option>
                }
                else
                {
                    <option value="@genero">
                        @genero
                    </option>
                }
            }

        </select>

    </form>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4 juego-card">

                <a asp-action="Detalle"
                   asp-route-id="@item.Id"
                   class="card-link">

                    <div class="card tarjeta-ps h-100">

                        <div class="contenedor-imagen">

                            <img src="@item.ImagenUrl"
                                 class="card-img-top imagen-juego" />

                            <div class="overlay-juego">

                                <span class="badge bg-primary">
                                    @item.Genero
                                </span>

                            </div>

                        </div>

                        <div class="card-body">

                            <h4 class="titulo-juego">
                                @item.Nombre
                            </h4>

                            <p class="desarrollador-juego">
                                @item.Desarrollador
                            </p>

                            <p class="descripcion-juego">
                                @item.Descripcion
                            </p>

                        </div>

                        <div class="card-footer footer-juego">

                            <span class="plataforma-juego">
                                @item.Plataforma
                            </span>

                            <a asp-action="Eliminar"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm"
                               onclick="event.stopPropagation(); return confirm('¿Eliminar este juego?');">

                                Eliminar

                            </a>

                        </div>

                    </div>

                </a>

            </div>
        }

    </div>
    <script>

            const buscador =
                document.getElementById("busquedaJuego");

            buscador.addEventListener("keyup", function () {

                const texto =
                    buscador.value.toLowerCase();

                const juegos =
                    document.querySelectorAll(".juego-card");

                juegos.forEach(juego => {

                    const nombre =
                        juego.innerText.toLowerCase();

                    if (nombre.includes(texto)) {

                        juego.style.display = "";

                    } else {

                        juego.style.display = "none";
                    }

                });

            });

    </script>

</div>