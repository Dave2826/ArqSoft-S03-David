@model List<CatalogoApp.Domain.Models.Item>

@{
    ViewData["Title"] = "PlayStation Game Catalog";
}

<div class="container mt-4">

    <h1 class="titulo-principal mb-4">
        PlayStation Game Catalog
    </h1>

    <form method="get" class="mb-4">

        <select name="genero"
                class="form-select filtro-ps"
                onchange="this.form.submit()">

            <option value="">
                Todos los géneros
            </option>

            @foreach (var genero in ViewBag.Generos)
            {
                if (ViewBag.GeneroActual == genero)
                {
                    <option value="@genero" selected>
                        @genero
                    </option>
                }
                else
                {
                    <option value="@genero">
                        @genero
                    </option>
                }
            }

        </select>

    </form>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card tarjeta-ps h-100">

                    <img src="@item.ImagenUrl"
                         class="card-img-top imagen-juego" />

                    <div class="card-body">

                        <h4>@item.Nombre</h4>

                        <p class="text-info">
                            @item.Desarrollador
                        </p>

                        <p>
                            @item.Descripcion
                        </p>

                        <span class="badge bg-primary">
                            @item.Genero
                        </span>

                    </div>

                    <div class="card-footer bg-transparent border-0">

                        <a asp-action="Detalle"
                           asp-route-id="@item.Id"
                           class="btn btn-ps-detalle">

                            Ver Detalle

                        </a>

                        <a asp-action="Eliminar"
                           asp-route-id="@item.Id"
                           class="btn btn-danger"
                           onclick="return confirm('¿Seguro que deseas eliminar este juego?');">

                            Eliminar

                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>