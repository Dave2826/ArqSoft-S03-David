@model CatalogoApp.Domain.Models.Item

@{
    ViewData["Title"] = "Detalle";
}

<div class="detalle-hero">

    <img src="@Model.ImagenUrl"
         class="detalle-bg" />

    <div class="detalle-overlay">

        <div class="container">

            <div class="detalle-contenido">

                <div class="detalle-info">

                    <span class="badge bg-primary mb-3">
                        @Model.Genero
                    </span>

                    <h1 class="detalle-titulo">
                        @Model.Nombre
                    </h1>

                    <h4 class="detalle-dev">
                        @Model.Desarrollador
                    </h4>

                    <p class="detalle-desc">
                        @Model.Descripcion
                    </p>

                    <div class="detalle-meta">

                        <div class="meta-card">

                            <span class="meta-label">
                                Plataforma
                            </span>

                            <span class="meta-value">
                                @Model.Plataforma
                            </span>

                        </div>

                        <div class="meta-card">

                            <span class="meta-label">
                                Duración
                            </span>

                            <span class="meta-value">
                                @Model.Duracion
                            </span>

                        </div>

                        <div class="meta-card">

                            <span class="meta-label">
                                Clasificación
                            </span>

                            <span class="meta-value">
                                @Model.Clasificacion
                            </span>

                        </div>

                        <div class="meta-card">

                            <span class="meta-label">
                                Año
                            </span>

                            <span class="meta-value">
                                @Model.Ano
                            </span>

                        </div>

                    </div>

                    <div class="mt-4">

                        <a asp-action="Index"
                           class="btn btn-ps me-2">

                            Volver al catálogo

                        </a>

                        <a asp-action="Eliminar"
                           asp-route-id="@Model.Id"
                           class="btn btn-danger"
                           onclick="return confirm('¿Eliminar este juego?');">

                            Eliminar

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>