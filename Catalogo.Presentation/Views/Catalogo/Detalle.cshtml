@model CatalogoApp.Domain.Models.Item

@{
    ViewData["Title"] = Model.Nombre;
}

<section class="detalle-container">

    <div class="detalle-banner"
         style="background-image: url('@Model.ImagenUrl');">

        <div class="detalle-overlay"></div>

        <div class="detalle-card">

            <div class="detalle-imagen-panel">

                <img src="@Model.ImagenUrl"
                     alt="@Model.Nombre"
                     class="detalle-imagen" />

            </div>

            <div class="detalle-info">

                <div class="detalle-badges">

                    <span class="detalle-badge">
                        @Model.Genero
                    </span>

                    <span class="detalle-badge">
                        @(Model.Ano?.ToString() ?? "S/N")
                    </span>

                    <span class="detalle-badge">
                        @Model.Clasificacion
                    </span>

                </div>

                <h1 class="detalle-titulo">
                    @Model.Nombre
                </h1>

                <p class="detalle-desarrollador">
                    @Model.Desarrollador
                </p>

                <p class="detalle-descripcion">
                    @Model.Descripcion
                </p>

                <div class="detalle-acciones">

                    <a asp-action="Index"
                       class="btn-volver">
                        Volver al catálogo
                    </a>

                    <form asp-action="FavoritoPost"
                          method="post"
                          class="d-inline">

                        <input type="hidden"
                               name="id"
                               value="@Model.Id" />

                        <input type="hidden"
                               name="returnUrl"
                               value="@(Context.Request.Path + Context.Request.QueryString)" />

                        <button type="submit"
                                class="btn-favorito-detalle @(Model.Favorito ? "favorito-activo" : string.Empty)">
                            @(Model.Favorito ? "❤" : "♡")
                        </button>

                    </form>

                </div>

            </div>

            <aside class="detalle-sidebar">

                <div class="detalle-sidebar-card">
                    <span>Plataforma</span>
                    <strong>@Model.Plataforma</strong>
                </div>

                <div class="detalle-sidebar-card">
                    <span>Duración</span>
                    <strong>@Model.Duracion</strong>
                </div>

                <div class="detalle-sidebar-card">
                    <span>Clasificación</span>
                    <strong>@Model.Clasificacion</strong>
                </div>

                <div class="detalle-sidebar-card">
                    <span>Favorito</span>
                    <strong>@(Model.Favorito ? "Sí" : "No")</strong>
                </div>

            </aside>

        </div>

    </div>

</section>
