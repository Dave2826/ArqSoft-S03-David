@using Microsoft.AspNetCore.Http
@using System.Text.Json
@{
    var favoritosJson = Context.Session.GetString("Favoritos");
    var cantidadFavoritos = string.IsNullOrWhiteSpace(favoritosJson)
        ? 0
        : JsonSerializer.Deserialize<List<int>>(favoritosJson)?.Count ?? 0;
    var toastMessage = TempData["Success"] as string
        ?? TempData["Error"] as string
        ?? TempData["Info"] as string;
    var toastType = TempData["Success"] != null
        ? "success"
        : TempData["Error"] != null
            ? "error"
            : TempData["Info"] != null
                ? "info"
                : "success";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - PlayStation Game Catalog</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/Catalogo.Presentation.styles.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>

<body>

    @if (!string.IsNullOrWhiteSpace(toastMessage))
    {
        <div class="toast-container"
             data-toast-message="@toastMessage"
             data-toast-type="@toastType">
        </div>
    }

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark navbar-ps">

    <div class="container">

        <a class="navbar-brand logo-ps"
           asp-controller="Catalogo"
           asp-action="Index">

            PLAYSTATION GAME CATALOG

        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarContenido">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse"
             id="navbarContenido">

            <ul class="navbar-nav ms-auto align-items-center">

                <li class="nav-item me-3">

                    <a class="nav-link"
                       asp-controller="Catalogo"
                       asp-action="Index">

                        Inicio

                    </a>

                </li>

                <li class="nav-item me-3">

                    <a class="nav-link"
                       asp-controller="Catalogo"
                       asp-action="Dashboard">

                        Dashboard

                    </a>

                </li>

                <li class="nav-item me-3">

                    <a class="nav-link"
                       asp-controller="Catalogo"
                       asp-action="Favoritos">

                        Favoritos
                        <span class="contador-favoritos">
                            @cantidadFavoritos
                        </span>

                    </a>

                </li>

                @if (Context.Session.GetString("Usuario") == null)
                {
                    <li class="nav-item me-2">

                        <a class="btn btn-outline-info"
                           asp-controller="Auth"
                           asp-action="Login">

                            Iniciar Sesión

                        </a>

                    </li>

                }
                else
                {
                    <li class="nav-item me-3">

                        <span class="usuario-activo">

                            Hola,
                            @Context.Session.GetString("Usuario")

                        </span>

                    </li>

                    <li class="nav-item me-3">

                        <a class="btn btn-ps"
                           asp-controller="Catalogo"
                           asp-action="Agregar">

                            Agregar Juego

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="btn btn-danger"
                           asp-controller="Auth"
                           asp-action="Logout">

                            Cerrar sesión

                        </a>

                    </li>
                }

            </ul>

        </div>

    </div>

</nav>

    </header>

    <div class="container mt-4">

    @if (Context.Session.GetString("Usuario") != null)
    {
        <div class="d-flex justify-content-end mb-3">

            <a asp-controller="Catalogo"
               asp-action="Agregar"
               class="btn btn-ps btn-global-agregar">

                Agregar Juego

            </a>

        </div>
    }

    <main role="main" class="pb-4">

        @RenderBody()

    </main>

</div>

    </div>

    <footer class="footer-ps mt-5">
        <div class="container text-center">

            © 2026 PlayStation Game Catalog
            | Arquitectura por capas ASP.NET Core MVC

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    <script src="~/js/toast.js"
            asp-append-version="true"></script>

    <script src="~/js/microanimations.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
