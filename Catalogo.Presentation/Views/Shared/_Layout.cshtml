<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - PlayStation Game Catalog</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/Catalogo.Presentation.styles.css"
          asp-append-version="true" />
</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark navbar-ps shadow-sm">

            <div class="container">

                <a class="navbar-brand fw-bold"
                   asp-controller="Catalogo"
                   asp-action="Index">

                    PLAYSTATION GAME CATALOG

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarContent">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Catalogo"
                               asp-action="Index">

                                Inicio

                            </a>

                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container mt-4">

    <div class="d-flex justify-content-end mb-3">

        <a asp-controller="Catalogo"
           asp-action="Agregar"
           class="btn btn-ps btn-global-agregar">

            Agregar Juego

        </a>

    </div>

    <main role="main" class="pb-4">

        @RenderBody()

    </main>

</div>


    </div>

    <footer class="footer-ps mt-5">

        <div class="container text-center">

            © 2026 PlayStation Game Catalog
            | Arquitectura por capas ASP.NET Core MVC

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>